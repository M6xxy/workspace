<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StarterApp.Views.ItemsListPage"
             xmlns:vm="clr-namespace:StarterApp.ViewModels"
             Title="{Binding Title}">

    <ContentPage.BindingContext>
        <vm:ItemsListViewModel />
    </ContentPage.BindingContext>

    <VerticalStackLayout>
        <Label Text="{Binding Message}"
               FontSize="24"
               VerticalOptions="Center"
               HorizontalOptions="Center" />

        <CollectionView ItemsSource="{Binding Listings}"
                        Margin="10">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="15"
                           Margin="5"
                           CornerRadius="12"
                           HasShadow="True">

                        <VerticalStackLayout Spacing="6">
                            <Label Text="{Binding ItemTitle}"
                                   FontSize="18"
                                   FontAttributes="Bold" />

                            <Label Text="{Binding ItemDescription}"
                                   FontSize="14" />

                            <Label Text="{Binding ItemCategory}"
                                   FontSize="14" />

                            <Label Text="{Binding ItemOwnerName}"
                                   FontSize="14" />

                            <Label Text="{Binding ItemRate}"
                                   FontSize="14" />
                        </VerticalStackLayout>

                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>
    </VerticalStackLayout>
</ContentPage>