<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StarterApp.Views.ItemsListPage"
             x:Name="ListingPage"
             xmlns:vm="clr-namespace:StarterApp.ViewModels"
             Title="{Binding Title}">


    <Grid RowDefinitions="Auto,*,Auto" Padding="10">
        <Label Text="{Binding Message}"
               Grid.Row="0"
               FontSize="24"
               VerticalOptions="Center"
               HorizontalOptions="Center" />

        <CollectionView ItemsSource="{Binding Listings}"
                        Grid.Row="1"
                        Margin="10">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="15"
                           Margin="5"
                           CornerRadius="12"
                           HasShadow="True">

                        <VerticalStackLayout Spacing="6">
                            <Label Text="{Binding ItemTitle}"
                                   FontSize="18"
                                   FontAttributes="Bold" />

                            <Label Text="{Binding ItemDescription}"
                                   FontSize="14" />

                            <Label Text="{Binding ItemCategory, StringFormat='Category: {0}'}"
                                   FontSize="14" />

                            <Label Text="{Binding ItemOwnerName, StringFormat='Owner: {0}'}"
                                   FontSize="14" />

                            <Label Text="{Binding ItemRate, StringFormat='Rate: £{0:F2}/day'}"
                                   FontSize="14" />

                            <HorizontalStackLayout Spacing="10" Margin="0,10,0,0">
                                <Button Text="View Details"
                                 Command="{Binding Source={x:Reference ListingPage}, Path=BindingContext.NavigateToListingDetailCommand}"
                                CommandParameter="{Binding .}" />

                                <Button Text="Edit Listing"
                                        IsVisible="{Binding CanEditt}"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditListingCommand}"
                                CommandParameter="{Binding .}" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>

                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        
        <HorizontalStackLayout Grid.Row="2"
                       HorizontalOptions="Center"
                       Spacing="10"
                       Margin="0,10,0,0">

            <Button Text="Previous"
            Command="{Binding PreviousPageCommand}" />

            <Button Text="Next"
            Command="{Binding NextPageCommand}" />

        </HorizontalStackLayout>
        
    </Grid>
</ContentPage>