<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StarterApp.Views.RentalsPage"
             Title="{Binding Title}">

    <Grid RowDefinitions="Auto,*"
          Padding="15">

        <!-- Top Buttons -->
        <HorizontalStackLayout Grid.Row="0"
                               Spacing="10"
                               HorizontalOptions="Center">

            <Button Text="Incoming Requests"
                    Command="{Binding LoadIncomingRentalsCommand}" />

            <Button Text="Outgoing Requests"
                    Command="{Binding LoadOutgoingRentalsCommand}" />

        </HorizontalStackLayout>

        <!-- Rental Requests List -->
        <CollectionView Grid.Row="1"
                        Margin="0,20,0,0"
                        ItemsSource="{Binding Rentals}">

            <CollectionView.ItemTemplate>
                <DataTemplate>

                    <Frame Padding="15"
               Margin="0,0,0,10"
               CornerRadius="12"
               HasShadow="True">

                        <VerticalStackLayout Spacing="6">

                            <Label Text="{Binding ItemTitle}"
                       FontSize="18"
                       FontAttributes="Bold" />

                            <Label Text="{Binding BorrowerName,
                                       StringFormat='Borrower: {0}'}"
                       FontSize="14" />

                            <Label Text="{Binding OwnerName,
                                       StringFormat='Owner: {0}'}"
                       FontSize="14" />

                            <Label Text="{Binding StartDate,
                                       StringFormat='Start: {0:dd/MM/yyyy}'}"
                       FontSize="14" />

                            <Label Text="{Binding EndDate,
                                       StringFormat='End: {0:dd/MM/yyyy}'}"
                       FontSize="14" />

                            <Label Text="{Binding TotalPrice,
                                       StringFormat='Total Price: £{0:F2}'}"
                       FontSize="14" />

                            <Label Text="{Binding RequestedAt,
                                       StringFormat='Requested: {0}'}"
                       FontSize="14" />

                            <Label Text="{Binding Status,
                                       StringFormat='Status Code: {0}'}"
                       FontSize="14"
                       FontAttributes="Bold" />

                        </VerticalStackLayout>

                    </Frame>

                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>
</ContentPage>